# ─────────────────────────────────────────────────────────────
# Echo — environment variables
# Copy to `.env.local` and fill in. Guest mode works with zero secrets,
# so you can start with just the AI keys for the speaking pipeline and
# add Google/DB/Blob later.
# ─────────────────────────────────────────────────────────────

# --- Database (Neon Postgres) ---
DATABASE_URL=

# --- Auth (Auth.js / NextAuth) ---
# Guest mode works with no config. Set AUTH_SECRET for stable JWT signing
# (generate with: npx auth secret). Add Google creds to enable Google login.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- LLM (multi-provider, default OpenAI) ---
# Set ECHO_LLM_PROVIDER to openai | anthropic | google and provide the matching
# key below — or route any provider through the Vercel AI Gateway.
ECHO_LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=
# Models in "provider/model" form. Bare ids default to ECHO_LLM_PROVIDER.
ECHO_EXAMINER_MODEL=openai/gpt-4o-mini
ECHO_SCORER_MODEL=openai/gpt-4o

# --- STT provider registry (default: deepgram) ---
ECHO_STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# --- TTS provider registry (default: elevenlabs) ---
ECHO_TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Realtime S2S (Mode B, experimental) ---
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- Feature flags ---
# chained = Mode A (STT->LLM->TTS); live = Mode B (Gemini Live S2S)
NEXT_PUBLIC_CONVERSATION_MODE=chained
